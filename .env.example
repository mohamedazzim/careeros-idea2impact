# CareerOS public configuration template
# Copy to .env for local use. Never commit populated .env files.
ENV_FILE=.env.example

# Core runtime
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-value
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/realtime

# PostgreSQL and Redis
POSTGRES_HOST_PORT=5432
POSTGRES_USER=careeros
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=careeros_db
DATABASE_URL=postgresql+asyncpg://careeros:change-me-local-only@db:5432/careeros_db
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Optional startup seed. Leave blank unless creating a local demo administrator.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=CareerOS Demo Administrator
SEED_ADMIN_ROLE=User

# Qdrant: local Docker by default; replace URL and add a key for Qdrant Cloud.
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_RAG_DOCS_COLLECTION=careeros_rag_docs

# LLM and embedding providers. At least one configured LLM is needed for AI generation.
PRIMARY_LLM_PROVIDER=gemini
PRIMARY_LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_REASONING_MODEL=gemini-2.5-flash
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
DEEPSEEK_MODEL=meta/llama-3.3-70b-instruct
RAG_EMBEDDING_MODEL=nvidia/nv-embed-v1
RAG_LLM_MODEL=gemini-2.5-flash

# Jobs provider. One active TheirStack key is enough; additional slots are optional.
THEIRSTACK_API_KEY=
THEIRSTACK_API_KEY_1=
THEIRSTACK_API_KEY_2=
THEIRSTACK_API_KEY_3=
THEIRSTACK_API_KEY_4=
THEIRSTACK_API_KEY_5=
THEIRSTACK_API_KEY_6=
THEIRSTACK_API_KEY_7=
THEIRSTACK_API_KEY_8=
THEIRSTACK_API_KEY_9=
THEIRSTACK_API_KEY_10=
THEIRSTACK_API_KEY_11=
THEIRSTACK_API_KEY_12=
THEIRSTACK_API_KEY_13=
THEIRSTACK_API_KEY_14=
THEIRSTACK_API_KEY_15=
THEIRSTACK_API_URL_1=
THEIRSTACK_API_URL_2=
THEIRSTACK_API_URL_3=
THEIRSTACK_API_URL_4=
THEIRSTACK_API_URL_5=
THEIRSTACK_API_URL_6=
THEIRSTACK_API_URL_7=
THEIRSTACK_API_URL_8=
THEIRSTACK_API_URL_9=
THEIRSTACK_API_URL_10=
THEIRSTACK_API_URL_11=
THEIRSTACK_API_URL_12=
THEIRSTACK_API_URL_13=
THEIRSTACK_API_URL_14=
THEIRSTACK_API_URL_15=
THEIRSTACK_MAX_QUERIES_PER_REFRESH=5
JOB_AUTO_REFRESH_ENABLED=false
JOB_AUTO_REFRESH_INTERVAL_MINUTES=30
JOB_AUTO_REFRESH_EMBED_BATCH_SIZE=50

# Docs-RAG and optional Make.com relay
MAKE_RAG_WEBHOOK_URL=
MAKE_RAG_API_KEY=
RAG_USE_MAKE=false

# Voice and conversational opportunity calls. Keep dry-run enabled for public setup.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TEST_PHONE_NUMBER=
ELEVENLABS_API_KEY=
ELEVENLABS_CONVAI_AGENT_ID=
ELEVENLABS_CONVAI_PHONE_NUMBER_ID=
# Legacy aliases supported by the backend
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
ELEVENLABS_PHONE_NUMBER_ID=
OUTBOUND_CALL_DRY_RUN=true
CALL_ALERT_DRY_RUN=true
OUTBOUND_TEST_TO_NUMBER=

# Speech-to-text and optional webhook integrations
DEEPGRAM_API_KEY=
PIPEDREAM_WEBHOOK_URL=

# LangSmith observability (disabled and fail-open by default)
LANGSMITH_ENABLED=false
LANGSMITH_FAIL_OPEN=true
LANGSMITH_429_COOLDOWN_SECONDS=3600
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=careeros
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Storage. Local storage requires no cloud credentials.
STORAGE_TYPE=local
STORAGE_BASE_PATH=/tmp/careeros_storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_ENDPOINT_URL=

# Verified learning-resource discovery
LEARNING_RESOURCES_ENABLED=true
LEARNING_RESOURCE_DISCOVERY_ENABLED=false
LEARNING_RESOURCE_PROVIDER=seeded+dynamic
LEARNING_RESOURCE_CACHE_TTL_HOURS=168
LEARNING_RESOURCE_MIN_RESULTS_PER_SKILL=3
LEARNING_RESOURCE_MAX_RESULTS_PER_SKILL=8
LEARNING_WEB_SEARCH_PROVIDER=tavily
LEARNING_WEB_SEARCH_ENABLED=false
LEARNING_WEB_SEARCH_TIMEOUT_SECONDS=20
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
TAVILY_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
UDEMY_CLIENT_ID=
UDEMY_CLIENT_SECRET=
UDEMY_AFFILIATE_ENABLED=false
COURSERA_DISCOVERY_ENABLED=true
LEARNING_WEB_SEARCH_ALLOWED_DOMAINS=["aws.amazon.com","docs.aws.amazon.com","dev.java","docs.oracle.com","openjdk.org","spring.io","freecodecamp.org","learn.microsoft.com","developer.mozilla.org","docs.docker.com","fastapi.tiangolo.com","git-scm.com","kubernetes.io","www.postgresql.org","react.dev","www.tensorflow.org","docs.pytorch.org","www.youtube.com","coursera.org","www.coursera.org","udemy.com","www.udemy.com"]
YOUTUBE_API_KEY=

# GitHub project discovery
GITHUB_REPO_DISCOVERY_ENABLED=false
GITHUB_TOKEN=
GITHUB_REPO_CACHE_TTL_HOURS=168
GITHUB_REPO_MIN_RESULTS_PER_SKILL=3
GITHUB_REPO_MAX_RESULTS_PER_SKILL=6
GITHUB_ISSUE_DISCOVERY_ENABLED=false

# Worker and local provider safety
WORKER_MAX_JOBS=10
WORKER_JOB_TIMEOUT=300
MOCK_MCP=true

# Optional image-based production Compose settings
REGISTRY=example.invalid
BACKEND_VERSION=latest
WORKER_VERSION=latest
FRONTEND_VERSION=latest
DOMAIN=your-domain.example.com
DEBUG=false
LOG_LEVEL=INFO
ALLOWED_HOSTS=your-domain.example.com
